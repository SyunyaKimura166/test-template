    }
  },
  "metadata": {
    "priority": "normal",
    "retry_count": 0,
    "ttl_seconds": 3600,
    "source": "github-actions",
    "github_context": {
      "repository": "{{REPOSITORY}}",
      "workflow": "{{WORKFLOW}}",
      "run_id": "{{RUN_ID}}",
      "run_number": "{{RUN_NUMBER}}",
      "actor": "{{ACTOR}}",
      "event_name": "{{EVENT_NAME}}",
      "ref": "{{REF}}"
    }
  }
