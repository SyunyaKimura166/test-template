# SSH connection settings
# Copy this file to .env and fill in your values

# SSH user (optional if using user@host format)
SSH_USER=your_username

# SSH password (optional - key auth is preferred)
SSH_PASSWORD=your_password

# SSH private key path (optional - alternative to password)
# SSH_KEY_PATH=/path/to/private/key

# SSH port (default: 22)
# SSH_PORT=22
